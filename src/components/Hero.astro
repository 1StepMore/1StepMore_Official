---
import '../styles/od-tokens.css';
---

<section class="hero">
  <div class="hero-inner">
    <div class="hero-content">
      <div class="hero-badge">
        <span class="badge-dot"></span>
        AI内容生产专家
      </div>
      <h1 class="hero-headline">
        <span class="headline-accent">AI Speed,</span><br/>Human Touch
      </h1>
      <p class="hero-subheadline">
        告别AI随机感，让AI成为创意的加速器。壹目贯维帮助企业建立从内容生产到多平台发布的高效流水线。
      </p>
      <div class="hero-actions">
        <a href="/1StepMore_Official/products/ai-content-studio" class="btn-primary">
          了解更多 →
        </a>
        <a href="/1StepMore_Official/blog" class="btn-secondary">
          查看案例 ↓
        </a>
      </div>
      <div class="hero-stats">
        <div class="stat">
          <div class="stat-value">70%</div>
          <div class="stat-label">成本降低</div>
        </div>
        <div class="stat">
          <div class="stat-value">20+</div>
          <div class="stat-label">日产文章量</div>
        </div>
        <div class="stat">
          <div class="stat-value">90%+</div>
          <div class="stat-label">审核通过率</div>
        </div>
      </div>
    </div>

    <div class="hero-visual" aria-hidden="true">
      <div class="hero-glow"></div>
      <div class="hero-card-stack">

        <div class="card-main">
          <div class="card-header">
            <span class="card-title">内容生产</span>
            <span class="card-badge">进行中</span>
          </div>
          <div class="content-block">
            <div class="content-icon">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
            </div>
            <div class="content-lines">
              <div class="line full"></div>
              <div class="line medium"></div>
            </div>
          </div>
          <div class="content-block">
            <div class="content-icon">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
            </div>
            <div class="content-lines">
              <div class="line full"></div>
              <div class="line short"></div>
            </div>
          </div>
          <div class="content-block">
            <div class="content-icon">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
            </div>
            <div class="content-lines">
              <div class="line medium"></div>
              <div class="line full"></div>
            </div>
          </div>
          <div class="card-progress">
            <div class="progress-label">
              <span>日目标完成</span>
              <span class="progress-pct">78%</span>
            </div>
            <div class="progress-bar"><div class="progress-fill"></div></div>
          </div>
        </div>

        <div class="mini-card mini-card-1">
          <div class="mini-icon green">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--mini-icon-green, #059669)" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <div>
            <div class="mini-text">12篇 已发布</div>
            <div class="mini-sub">今日已完成</div>
          </div>
        </div>

        <div class="mini-card mini-card-2">
          <div class="mini-icon purple">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--mini-icon-purple, #7C3AED)" stroke-width="2.5"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
          </div>
          <div>
            <div class="mini-text">AI审核通过</div>
            <div class="mini-sub">2分钟前</div>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<style>
  .hero { padding: 0; }

  .hero-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 8rem 3rem 5rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 4rem;
  }

  /* Badge */
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(99, 102, 241, 0.08);
    border: 1px solid rgba(99, 102, 241, 0.2);
    border-radius: 999px;
    padding: 0.35rem 1rem;
    font-family: var(--od-font-display);
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--od-color-ai-speed);
    margin-bottom: 1.5rem;
  }
  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--od-color-ai-speed);
    animation: blink 2s ease-in-out infinite;
  }
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.3} }

  /* Headline */
  .hero-headline {
    font-family: var(--od-font-display);
    font-size: clamp(2.5rem, 5vw, 3.8rem);
    font-weight: 700;
    color: var(--od-color-text-primary);
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin: 0 0 1.25rem;
  }
  .headline-accent {
    background: linear-gradient(135deg, var(--od-color-ai-speed) 0%, #818CF8 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* Subheadline */
  .hero-subheadline {
    font-family: var(--od-font-body);
    font-size: 1.2rem;
    color: var(--od-color-text-secondary);
    line-height: 1.7;
    margin: 0 0 2.5rem;
    max-width: 460px;
  }

  /* Actions */
  .hero-actions { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; }
  .btn-primary {
    font-family: var(--od-font-display);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--od-color-white);
    background: linear-gradient(135deg, var(--od-color-ai-speed) 0%, #4F46E5 100%);
    padding: 0.85rem 2rem;
    border-radius: var(--od-radius-human-touch);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    box-shadow: 0 4px 16px rgba(99, 102, 241, 0.35);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(99, 102, 241, 0.45); }
  .btn-secondary {
    font-family: var(--od-font-display);
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--od-color-text-secondary);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    transition: color 0.2s;
  }
  .btn-secondary:hover { color: var(--od-color-ai-speed); }

  /* Stats */
  .hero-stats { display: flex; gap: 2rem; margin-top: 3rem; padding-top: 2rem; border-top: 1px solid rgba(99, 102, 241, 0.1); }
  .stat-value { font-family: var(--od-font-display); font-size: 1.5rem; font-weight: 700; color: var(--od-color-ai-speed); }
  .stat-label { font-family: var(--od-font-display); font-size: 0.75rem; color: var(--od-color-text-secondary); }

  /* Visual */
  .hero-visual { position: relative; display: flex; align-items: center; justify-content: center; }
  .hero-glow {
    position: absolute; width: 500px; height: 500px; border-radius: 50%;
    background: radial-gradient(circle, rgba(99, 102, 241, 0.1) 0%, transparent 70%);
    top: 50%; left: 50%; transform: translate(-50%,-50%); pointer-events: none;
  }
  .hero-card-stack { position: relative; width: 420px; height: 420px; }

  /* Main card */
  .card-main {
    position: absolute; inset: 0;
    background: var(--od-color-white);
    border-radius: 20px;
    border: 1px solid rgba(99, 102, 241, 0.12);
    box-shadow: 0 20px 60px rgba(99, 102, 241, 0.12), 0 4px 16px rgba(0,0,0,0.06);
    padding: 2rem;
    display: flex; flex-direction: column;
    animation: float-main 6s ease-in-out infinite;
  }
  @keyframes float-main { 0%,100%{transform:translateY(0) rotate(0deg)} 50%{transform:translateY(-12px) rotate(0.5deg)} }

  .card-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem; }
  .card-title { font-family: var(--od-font-display); font-size: 0.8rem; font-weight: 600; color: var(--od-color-text-secondary); text-transform: uppercase; letter-spacing: 0.08em; }
  .card-badge { font-family: var(--od-font-display); font-size: 0.7rem; font-weight: 600; color: var(--od-color-ai-speed); background: rgba(99, 102, 241, 0.08); padding: 0.25rem 0.75rem; border-radius: 999px; }

  /* Content blocks */
  .content-block { background: var(--od-color-human-touch); border-radius: var(--od-radius-human-touch); padding: 0.75rem 1rem; margin-bottom: 0.75rem; display: flex; align-items: center; gap: 0.75rem; }
  .content-icon { width: 32px; height: 32px; border-radius: var(--od-radius-ai-speed); background: linear-gradient(135deg, var(--od-color-ai-speed), #818CF8); display: flex; align-items: center; justify-content: center; flex-shrink: 0; color: var(--od-color-white); }
  .content-lines { flex: 1; }
  .line { height: 8px; background: rgba(99, 102, 241, 0.12); border-radius: 4px; margin-bottom: 6px; }
  .line.short { width: 40%; }
  .line.medium { width: 65%; }
  .line.full { width: 100%; }

  /* Progress */
  .card-progress { margin-top: auto; padding-top: 1rem; border-top: 1px solid rgba(99, 102, 241, 0.08); }
  .progress-label { font-family: var(--od-font-display); font-size: 0.7rem; color: var(--od-color-text-secondary); margin-bottom: 0.5rem; display: flex; justify-content: space-between; }
  .progress-pct { color: var(--od-color-ai-speed); font-weight: 600; }
  .progress-bar { height: 6px; background: rgba(99, 102, 241, 0.12); border-radius: 3px; overflow: hidden; }
  .progress-fill { height: 100%; width: 78%; background: linear-gradient(90deg, var(--od-color-ai-speed), #818CF8); border-radius: 3px; }

  /* Mini cards */
  .mini-card { position: absolute; background: var(--od-color-white); border-radius: 12px; border: 1px solid rgba(99, 102, 241, 0.1); box-shadow: 0 8px 24px rgba(99, 102, 241, 0.1); padding: 0.75rem 1rem; display: flex; align-items: center; gap: 0.6rem; }
  .mini-card-1 { top: -20px; right: -20px; animation: float-mini-1 5s ease-in-out infinite; }
  .mini-card-2 { bottom: 40px; left: -30px; animation: float-mini-2 7s ease-in-out infinite; }
  @keyframes float-mini-1 { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-8px)} }
  @keyframes float-mini-2 { 0%,100%{transform:translateY(0)} 50%{transform:translateY(8px)} }
  .mini-icon { width: 36px; height: 36px; border-radius: 8px; display: flex; align-items: center; justify-content: center; }
  .mini-icon.green { background: #D1FAE5; }
  .mini-icon.purple { background: #EDE9FE; }
  .mini-text { font-family: var(--od-font-display); font-size: 0.75rem; font-weight: 600; color: var(--od-color-text-primary); }
  .mini-sub { font-family: var(--od-font-display); font-size: 0.65rem; color: var(--od-color-text-secondary); }

  /* Responsive */
  @media (max-width: 900px) {
    .hero-inner { grid-template-columns: 1fr; padding: 7rem 1.5rem 3rem; text-align: center; }
    .hero-subheadline { margin: 0 auto 2.5rem; }
    .hero-actions { justify-content: center; }
    .hero-visual { display: none; }
    .hero-stats { justify-content: center; }
  }
</style>
