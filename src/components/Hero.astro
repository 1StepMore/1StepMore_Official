---
import '../styles/od-tokens.css';
---

<section class="hero">
  <div class="hero-content">
    <h1 class="hero-headline">AI Speed, Human Touch</h1>
    <p class="hero-subheadline">告别AI随机感，让AI成为创意的加速器</p>
    <a href="/products" class="hero-cta">了解更多</a>
  </div>
</section>

<style>
  .hero {
    background-color: var(--od-color-human-touch);
    padding: var(--od-space-layout);
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-content {
    text-align: center;
    max-width: 800px;
  }

  .hero-headline {
    font-family: var(--od-font-display);
    font-size: 3rem;
    font-weight: 700;
    color: var(--od-color-text-primary);
    margin: 0 0 var(--od-space-layout);
    line-height: 1.2;
  }

  .hero-subheadline {
    font-family: var(--od-font-body);
    font-size: 1.25rem;
    color: var(--od-color-text-secondary);
    margin: 0 0 var(--od-space-layout);
    line-height: 1.6;
  }

  .hero-cta {
    font-family: var(--od-font-body);
    display: inline-block;
    background-color: var(--od-color-ai-speed);
    color: var(--od-color-white);
    padding: 0.75rem 2rem;
    border-radius: var(--od-radius-human-touch);
    text-decoration: none;
    font-size: 1rem;
    font-weight: 500;
    transition: opacity 0.2s ease;
  }

  .hero-cta:hover {
    opacity: 0.9;
  }
</style>