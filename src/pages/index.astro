---
import { getCollection } from 'astro:content';
import '../styles/od-tokens.css';

const allEntries = await getCollection('docs');
const products = allEntries.filter(entry => entry.data.type === 'product');
---

<div class="products-section">
  <h1 class="section-title">产品列表</h1>
  <p>Total entries: {allEntries.length}</p>
  <p>Products: {products.length}</p>

  <div class="products-grid">
    {products.map(product => (
      <article class="product-card">
        <h2>{product.data.title}</h2>
        <p class="product-pain-point">痛点：{product.data.pain_point}</p>
        <p class="product-core-selling">{product.data.core_selling}</p>
        <p class="product-price">{product.data.price}</p>
        <a href={"/docs/products/" + product.id + "/"} class="product-link">了解详情</a>
      </article>
    ))}
  </div>
</div>

<style>
  .products-section {
    padding: var(--od-space-layout) 0;
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-title {
    font-family: var(--od-font-display);
    color: var(--od-color-ai-speed);
    margin-bottom: var(--od-space-layout);
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--od-space-layout);
  }

  .product-card {
    background: var(--od-color-human-touch);
    border-radius: var(--od-radius-ai-speed);
    padding: var(--od-space-layout);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    border: 1px solid var(--od-color-ai-speed);
  }

  .product-card h2 {
    font-family: var(--od-font-display);
    color: var(--od-color-ai-speed);
    margin: 0;
    font-size: 1.25rem;
  }

  .product-pain-point {
    color: var(--od-color-text-secondary);
    font-size: 0.875rem;
    margin: 0;
  }

  .product-core-selling {
    color: var(--od-color-text-primary);
    font-family: var(--od-font-body);
    font-size: 1rem;
    line-height: 1.5;
    margin: 0;
    flex-grow: 1;
  }

  .product-price {
    font-family: var(--od-font-display);
    color: var(--od-color-ai-speed);
    font-weight: 600;
    font-size: 1.125rem;
    margin: 0;
  }

  .product-link {
    margin-top: auto;
    color: var(--od-color-ai-speed);
    font-weight: 600;
    text-decoration: none;
    padding: 0.5rem 1rem;
    border: 1px solid var(--od-color-ai-speed);
    border-radius: var(--od-radius-ai-speed);
    text-align: center;
  }

  .product-link:hover {
    background: var(--od-color-ai-speed);
    color: var(--od-color-human-touch);
  }
</style>